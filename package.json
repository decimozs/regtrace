{
	"name": "regtrace",
	"version": "0.10.0",
	"description": "LLM output evaluation toolkit: deterministic and LLM-judged metrics with quality gates, regression tracking, and CI integration",
	"type": "module",
	"private": true,
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/decimozs/regtrace.git"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "bun run scripts/build.ts",
		"lint": "biome check .",
		"format": "biome check --write .",
		"prepare": "lefthook install",
		"docs:dev": "bun run --cwd apps/docs dev",
		"docs:build": "bun run --cwd apps/docs build",
		"docs:start": "bun run --cwd apps/docs start",
		"docs:typecheck": "bun run --cwd apps/docs types:check",
		"stats": "bun scripts/download-stats.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/bun": "latest",
		"lefthook": "^2.1.9"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
