{
	"name": "regtrace",
	"version": "1.0.0",
	"type": "module",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "bun run scripts/build.ts",
		"lint": "biome check .",
		"format": "biome check --write .",
		"prepare": "lefthook install",
		"docs:dev": "bun run --cwd apps/docs dev",
		"docs:build": "bun run --cwd apps/docs build",
		"docs:start": "bun run --cwd apps/docs start",
		"docs:typecheck": "bun run --cwd apps/docs types:check"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/bun": "latest",
		"lefthook": "^2.1.9"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
